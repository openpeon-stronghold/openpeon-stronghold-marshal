{
  "cesp_version": "1.0",
  "name": "stronghold-marshal",
  "display_name": "The Marshal (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/ma_add_player_01.wav", "label": "More hell!" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/ma_willattack_01.wav", "label": "Absolutely" },
        { "file": "sounds/ma_sent_01.wav", "label": "Be a pleasure, sending now" },
        { "file": "sounds/ma_siege_01.wav", "label": "Off we go, siege time" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/ma_vict_01.wav", "label": "Carried the day" },
        { "file": "sounds/ma_boast_01.wav", "label": "Rah, chalked up another one" },
        { "file": "sounds/ma_vict_02.wav", "label": "Classic Guerrilla Tactics" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/ma_anger_01.wav", "label": "Bad tactics on my part" },
        { "file": "sounds/ma_anger_02.wav", "label": "Castle under attack" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/ma_help_01.wav", "label": "Sticky situation" },
        { "file": "sounds/ma_req_01.wav", "label": "Short on the basics" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/ma_notsent_01.wav", "label": "Can't send, sorry" },
        { "file": "sounds/ma_nohelp_01.wav", "label": "Can't help" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/ma_noattack_01.wav", "label": "Too dicey" },
        { "file": "sounds/ma_noattack_02.wav", "label": "Request denied, old man" },
        { "file": "sounds/ma_kick_player_01.wav", "label": "Bother!" }
      ]
    }
  }
}
